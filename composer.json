{
    "name": "kwaadpepper/sitemap-refresh",
    "description": "Create sitemap.xml",
    "license": "MIT",
    "authors": [
        {
            "name": "Jérémy Munsch",
            "email": "github@jeremydev.ovh",
            "homepage": "https://jeremydev.ovh"
        }
    ],
    "keywords": [
        "Laravel",
        "Sitemap"
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "~11|~12|~13",
        "laravel/framework": "~11|~12|~13",
        "spatie/laravel-sitemap": "^7.4"
    },
    "autoload": {
        "psr-4": {
            "Kwaadpepper\\SitemapRefresh\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kwaadpepper\\SitemapRefresh\\SitemapRefreshServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kwaadpepper\\SitemapRefresh\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "slevomat/coding-standard": "^8.11",
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
